{
  "name": "signalk-net-weather-finland",
  "version": "0.6.0",
  "description": "Finnish Meteorological Institute coastal weather station data for Signal K",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});\"",
    "build": "npm run clean && tsc -p tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test test/**/*.test.js",
    "lint": "eslint test/**/*.js && npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "audit-check": "npm audit --audit-level=moderate"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-weather"
  ],
  "repository": "https://github.com/KEGustafsson/signalk-net-weather-finland",
  "author": "Karl-Erik Gustafsson",
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^5.5.10",
    "haversine": "^1.1.1"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "typescript": "^5.8.3"
  }
}
